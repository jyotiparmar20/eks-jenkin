pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps { 
                git branch: 'main',
                   url: 'https://github.com/jyotiparmar20/eks-jenkin.git'
            }
        }

        stage('Terraform Init & Apply') {
            steps {
                sh '''
                cd terraform
                terraform init
                terraform apply -auto-approve
                '''
            }
        }

        stage('Deploy to EKS') {
            steps {
                sh '''
                aws eks --region us-east-1 update-kubeconfig --name three-tier-eks
                kubectl apply -f main.yaml
                '''
            }
        }
    }
}
