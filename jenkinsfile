pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/jyotiparmar20/eks-jenkin.git'
            }
        }

        stage('Deploy to EKS') {
            steps {
                sh '''
                aws eks --region us-east-1 update-kubeconfig --name three-tier-eks
                kubectl apply -f main.yaml
                '''
            }
        }
    }
}
