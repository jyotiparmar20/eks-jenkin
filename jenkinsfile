pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps { 
                git branch: 'main',
                   url: 'https://github.com/jyotiparmar20/eks-jenkin.git'
            }
        }

        stage('Terraform Init & Apply') {
            steps {
                sh '''    
                 terraform init
                terraform apply -auto-approve
                '''
            }
        }
    }
}
